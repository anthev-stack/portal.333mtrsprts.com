# PostgreSQL (Docker Compose default below matches these values)
DATABASE_URL="postgresql://portal:portal@localhost:5432/portal?schema=public"

# Auth — use a long random string (32+ characters)
JWT_SECRET="replace-with-a-long-random-secret-at-least-32-chars"

# Optional JWT lifetime (default 7d)
# JWT_EXPIRES="7d"

# Public URL used in password-reset emails and share links
NEXT_PUBLIC_APP_URL="https://portal.333mtrsprts.com"

# Optional: Giphy API key for GIF search in mail composer
# NEXT_PUBLIC_GIPHY_API_KEY="your-giphy-api-key"

# --- Outbound email (portal Mail + password reset) ---
# Verify DNS (SPF, DKIM, DMARC) for 333mtrsprts.com with your provider.
# Without these variables, mail stays portal-only and resets log the link server-side.
#
# Typical: Google Workspace, Microsoft 365, Resend (smtp.resend.com), SendGrid, etc.
# SMTP_PASS is preferred; SMTP_PASSWORD is accepted as an alias.
#
# SMTP_HOST="smtp.resend.com"
# SMTP_PORT="587"
# SMTP_SECURE="0"
# SMTP_USER="resend"
# SMTP_PASS="re_xxxxxxxx"
#
# From address must be allowed by your provider (often a verified domain mailbox or noreply).
# MAIL_FROM="333 Motorsports <noreply@333mtrsprts.com>"
#
# Reply-To on portal-sent mail defaults to the sender's internal @333mtrsprts.com address.
# MAIL_REPLY_TO_SENDER="0"
#
# For portal users: send SMTP copy to external (personal) inbox vs internal @domain mailbox
# MAIL_DELIVERY_TARGET="external"
# MAIL_DELIVERY_TARGET="internal"

# Node
NODE_ENV="production"
