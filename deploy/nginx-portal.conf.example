# Example Nginx site for portal.333mtrsprts.com — TLS terminates here, proxy to Next.js

upstream portal_app {
    server 127.0.0.1:3000;
    keepalive 64;
}

server {
    listen 80;
    listen [::]:80;
    server_name portal.333mtrsprts.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name portal.333mtrsprts.com;

    ssl_certificate     /etc/letsencrypt/live/portal.333mtrsprts.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/portal.333mtrsprts.com/privkey.pem;

    client_max_body_size 25m;

    location / {
        proxy_pass         http://portal_app;
        proxy_http_version 1.1;
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_set_header   Upgrade $http_upgrade;
        proxy_set_header   Connection "upgrade";
    }
}
